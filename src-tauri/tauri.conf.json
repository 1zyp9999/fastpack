{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "FastPack",
  "version": "1.0.0",
  "identifier": "com.fastpack",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "FastPack - 超快打包工具",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [],
    "category": "DeveloperTool",
    "shortDescription": "Ultra-fast cross-platform package builder",
    "longDescription": "FastPack is a high-performance cross-platform package builder with a modern GUI"
  },
  "plugins": {}
}